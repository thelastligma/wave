{
  "name": "wave",
  "version": "1.0.0",
  "description": "Wave ui",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac-arm": "electron-builder --mac --arm64",
    "build:mac-intel": "electron-builder --mac --x64",
    "build:mac-universal": "electron-builder --mac --universal"
  },
  "build": {
    "appId": "com.wave.app",
    "productName": "Wave",
    "icon": "build/icon.png",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "zip",
        "dmg"
      ]
    }
  },
  "devDependencies": {
    "electron": "^26.6.10",
    "electron-builder": "^26.8.1"
  }
}
